        <p class="text-muted small">Get your Account SID, Auth Token and a From number from your Twilio console -- leave the token blank to keep the current one.</p>

        <form method="post" action="<?= url('/notifications/settings/sms') ?>" class="row g-2 mb-3">
          <?= csrf_field() ?>
          <div class="col-md-12">
            <label class="form-label small mb-0">Account SID</label>
            <input type="text" name="twilio_account_sid" class="form-control form-control-sm" value="<?= e($sms['TWILIO_ACCOUNT_SID'] ?? '') ?>" placeholder="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx">
          </div>
          <div class="col-md-12">
            <label class="form-label small mb-0">Auth Token</label>
            <input type="password" name="twilio_auth_token" class="form-control form-control-sm" value="" placeholder="<?= !empty($sms['TWILIO_AUTH_TOKEN']) ? 'Leave blank to keep current token' : 'Not set' ?>">
          </div>
          <div class="col-md-12">
            <label class="form-label small mb-0">From Number</label>
            <input type="text" name="twilio_from_number" class="form-control form-control-sm" value="<?= e($sms['TWILIO_FROM_NUMBER'] ?? '') ?>" placeholder="+15555550100">
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-info btn-sm waves-effect waves-light"><i class="mdi mdi-content-save"></i> Save SMS Settings</button>
          </div>
        </form>

        <h6 class="mb-2">Send Test SMS</h6>
        <form method="post" action="<?= url('/notifications/settings/sms/test') ?>" class="row g-2">
          <?= csrf_field() ?>
          <div class="col-md-8">
            <input type="text" name="test_recipient" class="form-control form-control-sm" placeholder="+264811234567" required>
          </div>
          <div class="col-md-4">
            <button type="submit" class="btn btn-outline-secondary btn-sm w-100"><i class="mdi mdi-message-fast-outline"></i> Send Test</button>
