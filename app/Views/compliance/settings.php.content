          <?= csrf_field() ?>
          <div class="col-md-4">
            <label class="form-label small mb-0">Rate (%)</label>
            <input type="number" step="0.0001" name="levy_rate" class="form-control form-control-sm" value="<?= old('levy_rate', $old) ?>">
          </div>
          <div class="col-md-4">
            <label class="form-label small mb-0">Basis</label>
            <select name="calculation_basis" class="form-select form-select-sm">
              <?php foreach (['Principal Amount', 'Interest Amount', 'Total Payable', 'Outstanding Balance'] as $b): ?>
                <option value="<?= e($b) ?>"><?= e($b) ?></option>
              <?php endforeach; ?>
            </select>
          </div>
          <div class="col-md-4">
