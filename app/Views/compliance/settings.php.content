<?= flash_messages() ?>

<?php
  // is_active only ever tracks whether a row has been retracted, not
  // whether it's the one currently in effect -- that's date-range logic,
  // computed here for display since a future-dated new rate must not make
  // its still-current predecessor look inactive.
  $rateStatus = function (array $s): array {
    $today = date('Y-m-d');
    if ($s['effective_from'] > $today) {
      return ['Scheduled', 'info'];
    }
    if ($s['effective_to'] && $s['effective_to'] < $today) {
      return ['Superseded', 'secondary'];
    }
    return ['Current', 'success'];
  };
?>

<div class="row">
  <div class="col-lg-6 mb-3">
    <div class="card h-100">
      <div class="card-body">
        <h4 class="card-title mb-3">NAMFISA Levy Rate History</h4>

        <div class="table-responsive mb-3">
          <table class="table table-sm table-bordered">
            <thead><tr><th>Rate</th><th>Basis</th><th>Effective From</th><th>Effective To</th><th>Status</th></tr></thead>
            <tbody>
              <?php if (empty($namfisaSettings)): ?>
                <tr><td colspan="5" class="text-center text-muted py-3">No rates configured.</td></tr>
              <?php endif; ?>
              <?php foreach ($namfisaSettings as $s): ?>
                <tr>
                  <td><?= e($s['levy_rate']) ?>%</td>
                  <td><?= e($s['calculation_basis']) ?></td>
                  <td><?= e($s['effective_from']) ?></td>
                  <td><?= e($s['effective_to']) ?: 'Open-ended' ?></td>
                  <td><?php [$label, $badgeColor] = $rateStatus($s); ?><span class="badge bg-<?= $badgeColor ?>"><?= $label ?></span></td>
                </tr>
              <?php endforeach; ?>
            </tbody>
          </table>
        </div>

        <h6>Add New Rate</h6>
