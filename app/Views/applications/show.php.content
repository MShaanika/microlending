          </div>
          <p class="text-muted small mt-2 mb-0">DTI = (Existing Deductions + Proposed Installment) &divide; Gross Salary &times; 100. Under 50% Healthy, 50-70% Manageable, 70%+ High Risk.</p>
          <?php if ($screening['screening_notes']): ?><p class="mt-2 mb-0 text-muted"><?= e($screening['screening_notes']) ?></p><?php endif; ?>
