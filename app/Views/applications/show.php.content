        <p class="mb-1">Term: <?= (int) $application['requested_term_months'] ?> mo</p>
        <p class="mb-1">Purpose: <?= e($application['requested_purpose']) ?: '&mdash;' ?></p>
        <p class="mb-1">Employer: <?= e($application['employer_name']) ?: '&mdash;' ?></p>
        <p class="mb-1">Gross Salary: <?= format_money($application['gross_salary']) ?></p>
        <p class="mb-0">Net Salary: <?= format_money($application['net_salary']) ?></p>
