      </div>
    <?php endif; ?>

    <?php if ($bankAnalysis): ?>
      <div class="card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <h4 class="card-title"><i class="mdi mdi-robot-outline me-1"></i> AI Bank Statement Analysis</h4>
            <span class="badge bg-<?= $bankAnalysis['status'] === 'Completed' ? 'success' : 'danger' ?>"><?= e($bankAnalysis['status']) ?></span>
          </div>

          <?php if ($bankAnalysis['status'] === 'Failed'): ?>
            <p class="text-danger mb-0"><?= e($bankAnalysis['error_message']) ?></p>
          <?php else: ?>
            <p class="text-muted small mb-3">
              Based on <?= (int) $bankAnalysis['months_covered'] ?> month(s) of activity from
              <?= $bankAnalysis['statement_format'] === 'Merged' ? 'one merged statement file' : 'separate statement files' ?>.
            </p>
            <div class="row">
              <div class="col-md-3"><p class="mb-1 text-muted small">Avg. Monthly Income</p><p class="mb-0"><strong><?= format_money($bankAnalysis['average_monthly_income']) ?></strong></p></div>
              <div class="col-md-3"><p class="mb-1 text-muted small">Avg. Monthly Expenses</p><p class="mb-0"><strong><?= format_money($bankAnalysis['average_monthly_expenses']) ?></strong></p></div>
              <div class="col-md-3"><p class="mb-1 text-muted small">Avg. Closing Balance</p><p class="mb-0"><strong><?= format_money($bankAnalysis['average_closing_balance']) ?></strong></p></div>
              <div class="col-md-3"><p class="mb-1 text-muted small">NSF / Bounced Events</p><p class="mb-0"><strong><?= (int) $bankAnalysis['nsf_count'] ?></strong></p></div>
            </div>

            <?php $commitments = json_decode($bankAnalysis['existing_commitments'] ?: '[]', true); ?>
            <?php if (!empty($commitments)): ?>
              <p class="mt-3 mb-1 text-muted small">Existing Loans, Policies &amp; Accounts Detected (Total: <?= format_money($bankAnalysis['existing_commitments_total']) ?>/month)</p>
              <table class="table table-sm">
                <thead>
                  <tr><th>Type</th><th>Creditor / Company</th><th>Detail</th><th class="text-end">Monthly Amount</th></tr>
                </thead>
                <tbody>
                  <?php foreach ($commitments as $c): ?>
                    <?php
                      $typeBadge = match ($c['type'] ?? '') {
                        'Loan' => 'danger',
                        'Insurance Policy' => 'info',
                        'Retail/Furniture Account', 'Store Card' => 'warning',
                        'Credit Card' => 'dark',
                        default => 'secondary',
                      };
                    ?>
                    <tr>
                      <td><span class="badge bg-<?= $typeBadge ?>"><?= e($c['type'] ?? 'Other') ?></span></td>
                      <td><?= e($c['creditor_name'] ?? 'Unknown') ?></td>
                      <td class="text-muted small"><?= e($c['description'] ?? '') ?></td>
                      <td class="text-end"><?= format_money($c['monthly_amount'] ?? 0) ?></td>
                    </tr>
                  <?php endforeach; ?>
                </tbody>
              </table>
            <?php endif; ?>

            <?php if ($bankAnalysis['ai_summary']): ?>
              <p class="mt-2 mb-0 text-muted"><?= e($bankAnalysis['ai_summary']) ?></p>
            <?php endif; ?>
            <p class="text-muted small mt-2 mb-0">Model: <?= e($bankAnalysis['model_used']) ?> &bull; Analyzed <?= e(date('d M Y H:i', strtotime($bankAnalysis['analyzed_at']))) ?></p>
          <?php endif; ?>
        </div>
      </div>
    <?php endif; ?>

    <div class="card">
      <div class="card-body">
        <h4 class="card-title"><i class="mdi mdi-timeline-clock me-1"></i> Status History</h4>
        <ul class="list-unstyled mb-0">
          <?php foreach ($history as $h): ?>
            <li class="mb-2 pb-2 border-bottom">
              <strong><?= e($h['new_status']) ?></strong>
              <span class="text-muted small"> &mdash; <?= e(date('d M Y H:i', strtotime($h['changed_at']))) ?></span>
              <?php if ($h['notes']): ?><br><span class="text-muted"><?= e($h['notes']) ?></span><?php endif; ?>
