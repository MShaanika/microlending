                  <td><?= e(date('d M Y', strtotime($doc['uploaded_at']))) ?></td>
                  <td class="text-end">
                    <a href="<?= url('/applications/' . $application['id'] . '/documents/' . $doc['id']) ?>" target="_blank" class="btn btn-sm btn-outline-info"><i class="mdi mdi-download"></i></a>
                  </td>
                </tr>
              <?php endforeach; ?>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <?php if ($screening): ?>
      <?php
        $riskBand = match ($screening['risk_level']) {
          'Low' => ['label' => 'Healthy', 'badge' => 'success'],
          'Medium' => ['label' => 'Manageable', 'badge' => 'warning'],
          default => ['label' => 'High Risk', 'badge' => 'danger'],
        };
      ?>
      <div class="card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <h4 class="card-title"><i class="mdi mdi-calculator me-1"></i> Latest Screening</h4>
            <span class="badge bg-<?= ($screening['data_source'] ?? 'Self-Reported') === 'AI Bank Statement' ? 'primary' : 'secondary' ?>">
              <?= ($screening['data_source'] ?? 'Self-Reported') === 'AI Bank Statement' ? 'AI Bank Statement' : 'Self-Reported' ?>
            </span>
          </div>
          <div class="row">
            <div class="col-md-3"><p class="mb-1 text-muted small">Disposable Income</p><p class="mb-0"><strong><?= format_money($screening['disposable_income']) ?></strong></p></div>
            <div class="col-md-3">
              <p class="mb-1 text-muted small">Debt-to-Income Ratio</p>
              <p class="mb-0"><strong><?= e($screening['debt_to_income_ratio']) ?>%</strong> <span class="badge bg-<?= $riskBand['badge'] ?>"><?= $riskBand['label'] ?></span></p>
            </div>
