</div>

<div class="row">
  <div class="col-lg-8 mb-3">
    <div class="card h-100">
      <div class="card-header"><strong>Bad Debt / Write-Off Summary</strong> <span class="text-muted small">by status &amp; aging bucket</span></div>
      <div class="card-body">
        <?php if (empty($badDebtWriteOffSummary)): ?>
          <p class="text-center text-muted py-4">No bad debt activity in this period.</p>
        <?php else: ?>
          <div id="writeOffChart"></div>
          <table class="table table-sm table-bordered mt-2 no-datatable">
            <thead><tr><th>Status</th><th>Aging Bucket</th><th class="text-end">Loans</th><th class="text-end">Outstanding</th></tr></thead>
            <tbody>
              <?php foreach ($badDebtWriteOffSummary as $row): ?>
                <tr>
                  <td><?= e($row['status']) ?></td>
                  <td><?= e($row['aging_bucket']) ?> days</td>
                  <td class="text-end"><?= (int) $row['loan_count'] ?></td>
                  <td class="text-end"><?= format_money($row['total_outstanding']) ?></td>
                </tr>
              <?php endforeach; ?>
            </tbody>
          </table>
        <?php endif; ?>
      </div>
    </div>
  </div>

  <div class="col-lg-4 mb-3">
    <div class="card h-100">
      <div class="card-header"><strong>Recoveries</strong></div>
      <div class="card-body text-center d-flex flex-column justify-content-center h-100">
        <i class="mdi mdi-cash-refund display-4 text-success"></i>
        <h3 class="mt-2 mb-0"><?= format_money($recoverySummary['total_recovered']) ?></h3>
        <span class="text-muted">recovered across <?= (int) $recoverySummary['recovery_count'] ?> payment(s)</span>
      </div>
    </div>
  </div>
</div>

<script src="<?= asset('assets/libs/apexcharts/dist/apexcharts.min.js') ?>"></script>
<script>
(function () {
  var levyTrend = <?= json_encode($namfisaLevySummary['trend']) ?>;
  var stampTrend = <?= json_encode($dutyStampSummary['trend']) ?>;
  var writeOffData = <?= json_encode($badDebtWriteOffSummary) ?>;

  if (levyTrend.length) {
    new ApexCharts(document.getElementById('levyChart'), {
      chart: { type: 'line', height: 220, toolbar: { show: false } },
      series: [{ name: 'Levy', data: levyTrend.map(function (r) { return r.total_amount; }) }],
      xaxis: { categories: levyTrend.map(function (r) { return r.month_label; }) },
      colors: ['#635bff'],
      dataLabels: { enabled: false },
      stroke: { curve: 'smooth', width: 2 },
    }).render();
  }

  if (stampTrend.length) {
    new ApexCharts(document.getElementById('stampChart'), {
      chart: { type: 'line', height: 220, toolbar: { show: false } },
      series: [{ name: 'Duty Stamp', data: stampTrend.map(function (r) { return r.total_amount; }) }],
      xaxis: { categories: stampTrend.map(function (r) { return r.month_label; }) },
      colors: ['#ffb400'],
      dataLabels: { enabled: false },
      stroke: { curve: 'smooth', width: 2 },
    }).render();
  }

  if (writeOffData.length) {
    var buckets = [];
    var byBucket = {};
    writeOffData.forEach(function (r) {
      if (!byBucket[r.aging_bucket]) { byBucket[r.aging_bucket] = 0; buckets.push(r.aging_bucket); }
      byBucket[r.aging_bucket] += parseFloat(r.total_outstanding);
    });
    new ApexCharts(document.getElementById('writeOffChart'), {
      chart: { type: 'bar', height: 240, toolbar: { show: false } },
      series: [{ name: 'Outstanding', data: buckets.map(function (b) { return byBucket[b]; }) }],
      xaxis: { categories: buckets.map(function (b) { return b + ' days'; }) },
      colors: ['#ff5c75'],
      dataLabels: { enabled: false },
      plotOptions: { bar: { columnWidth: '45%', borderRadius: 4 } },
    }).render();
  }
})();
</script>
