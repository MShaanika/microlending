        <table class="table table-sm table-bordered mt-2 no-datatable">
          <thead><tr><th>Status</th><th class="text-end">Transactions</th><th class="text-end">Amount</th></tr></thead>
          <tbody>
            <?php if (empty($namfisaLevySummary['by_status'])): ?>
              <tr><td colspan="3" class="text-center text-muted py-3">No NAMFISA levy transactions in this period.</td></tr>
            <?php endif; ?>
