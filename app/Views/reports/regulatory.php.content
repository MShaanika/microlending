  </div>

  <div class="col-lg-6 mb-3">
    <div class="card h-100">
      <div class="card-header"><strong>Duty Stamp</strong> <span class="text-muted small">Total: <?= format_money($dutyStampSummary['total_amount']) ?></span></div>
      <div class="card-body">
        <div id="stampChart"></div>
        <table class="table table-sm table-bordered mt-2 no-datatable">
          <thead><tr><th>Status</th><th class="text-end">Transactions</th><th class="text-end">Amount</th></tr></thead>
          <tbody>
            <?php if (empty($dutyStampSummary['by_status'])): ?>
              <tr><td colspan="3" class="text-center text-muted py-3">No duty stamp transactions in this period.</td></tr>
            <?php endif; ?>
            <?php foreach ($dutyStampSummary['by_status'] as $row): ?>
              <tr>
                <td><?= e($row['status']) ?></td>
                <td class="text-end"><?= (int) $row['txn_count'] ?></td>
                <td class="text-end"><?= format_money($row['total_amount']) ?></td>
              </tr>
            <?php endforeach; ?>
          </tbody>
        </table>
      </div>
