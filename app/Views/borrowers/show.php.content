            <tbody>
              <?php if (empty($contacts)): ?>
                <tr><td colspan="5" class="text-center text-muted py-3">No contacts on file.</td></tr>
              <?php endif; ?>
              <?php foreach ($contacts as $c): ?>
                <tr>
                  <td><span class="badge bg-secondary"><?= e($c['contact_type']) ?></span></td>
                  <td><?= e($c['full_name']) ?></td>
                  <td><?= e($c['relationship'] ?: '&mdash;') ?></td>
                  <td><?= e($c['phone'] ?: '&mdash;') ?></td>
                  <td><?= e($c['email'] ?: '&mdash;') ?></td>
                </tr>
              <?php endforeach; ?>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-body">
        <h4 class="card-title"><i class="mdi mdi-file-document me-1"></i> Documents</h4>
        <div class="table-responsive">
          <table class="table table-sm table-hover">
            <thead>
              <tr><th>Document</th><th>Type</th><th>Status</th><th>Uploaded</th><th class="text-end">Action</th></tr>
            </thead>
            <tbody>
              <?php if (empty($documents)): ?>
                <tr><td colspan="5" class="text-center text-muted py-3">No documents uploaded.</td></tr>
              <?php endif; ?>
              <?php foreach ($documents as $doc): ?>
                <?php
                  $docBadge = match ($doc['status']) {
                    'Verified' => 'success',
                    'Rejected' => 'danger',
                    default => 'warning',
                  };
                ?>
                <tr>
                  <td><?= e($doc['document_name'] ?: $doc['document_type']) ?></td>
                  <td><?= e($doc['document_type']) ?></td>
                  <td><span class="badge bg-<?= $docBadge ?>"><?= e($doc['status']) ?></span></td>
                  <td><?= e(date('d M Y', strtotime($doc['uploaded_at']))) ?></td>
                  <td class="text-end">
                    <a href="<?= url('/borrowers/' . $borrower['id'] . '/documents/' . $doc['id']) ?>" target="_blank" class="btn btn-sm btn-outline-info"><i class="mdi mdi-download"></i></a>
                  </td>
                </tr>
              <?php endforeach; ?>
            </tbody>
          </table>
