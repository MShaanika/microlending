<?= flash_messages() ?>

<?php
  $badge = match ($borrower['status']) {
    'Approved' => 'success',
    'Rejected' => 'danger',
    'Blacklisted' => 'dark',
    'Inactive' => 'secondary',
    default => 'warning',
  };
?>

<div class="row">
  <div class="col-lg-4">
    <div class="card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <h4 class="card-title"><?= e($borrower['first_name'] . ' ' . $borrower['last_name']) ?></h4>
          <span class="badge bg-<?= $badge ?>"><?= e($borrower['status']) ?></span>
        </div>
        <p class="text-muted mb-1"><?= e($borrower['borrower_no']) ?></p>
