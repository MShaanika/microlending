              <p class="mb-1">Started: <?= e($employment['employment_start_date'] ?: '&mdash;') ?></p>
              <p class="mb-0">Employer Contact: <?= e($employment['employer_phone'] ?: '&mdash;') ?> <?= $employment['employer_email'] ? '/ ' . e($employment['employer_email']) : '' ?></p>
