          <a href="<?= url('/notifications/compose?borrower_id=' . $borrower['id']) ?>" class="btn btn-sm btn-outline-secondary"><i class="mdi mdi-bell-ring-outline"></i> Notify Borrower</a>
        </div>
      </div>
