              <p class="mb-1">Type: <?= e($bank['account_type'] ?: '&mdash;') ?></p>
              <p class="mb-0">Branch: <?= e($bank['branch_name'] ?: '&mdash;') ?> <?= $bank['branch_code'] ? '(' . e($bank['branch_code']) . ')' : '' ?></p>
            <?php endif; ?>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-body">
        <h4 class="card-title"><i class="mdi mdi-account-multiple me-1"></i> Next of Kin / Contacts</h4>
        <div class="table-responsive">
          <table class="table table-sm table-hover">
            <thead>
              <tr><th>Type</th><th>Name</th><th>Relationship</th><th>Phone</th><th>Email</th></tr>
