    <div class="card">
      <div class="card-body">
        <h4 class="card-title"><i class="mdi mdi-account-key me-1"></i> Borrower Portal Access</h4>
        <?php if ($portalUser): ?>
          <p class="mb-1">Username: <strong><?= e($portalUser['username']) ?></strong></p>
          <p class="mb-1">Status: <span class="badge bg-<?= $portalUser['is_active'] ? 'success' : 'secondary' ?>"><?= $portalUser['is_active'] ? 'Active' : 'Disabled' ?></span></p>
          <p class="mb-3 text-muted small">Last login: <?= $portalUser['last_login'] ? e(date('d M Y H:i', strtotime($portalUser['last_login']))) : 'Never' ?></p>
        <?php else: ?>
          <p class="text-muted mb-3">This borrower doesn't have portal access yet.</p>
        <?php endif; ?>
        <form method="post" action="<?= url('/borrowers/' . $borrower['id'] . '/portal-access') ?>" onsubmit="return confirm('<?= $portalUser ? 'Reset this borrower\'s portal password?' : 'Create portal access for this borrower?' ?>');">
          <?= csrf_field() ?>
          <button type="submit" class="btn btn-sm btn-outline-info"><i class="mdi mdi-key"></i> <?= $portalUser ? 'Reset Password' : 'Create Portal Access' ?></button>
        </form>
      </div>
    </div>
