                  <td><span class="badge bg-info"><?= e($loan['loan_status']) ?></span></td>
                  <td class="text-end">
                    <a href="<?= url('/loans/' . $loan['id']) ?>" class="btn btn-sm btn-outline-info"><i class="mdi mdi-eye"></i></a>
